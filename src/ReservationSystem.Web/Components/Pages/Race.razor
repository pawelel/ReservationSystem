@page "/race"
@rendermode InteractiveServer
@using Microsoft.Extensions.Localization
@using ReservationSystem.Web.Demo
@inject IReservationService Service
@inject RaceRunner Runner
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Race_Title"]</PageTitle>

<h1>@L["Race_Title"]</h1>
<p>@L["Race_Description"]</p>

<section class="card">
    <div class="row">
        <label>
            @L["Desk"]
            <select @bind="_deskId">
                @foreach (var d in _desks)
                {
                    <option value="@d.Id">@d.Name</option>
                }
            </select>
        </label>

        <label>
            @L["From"]
            <input type="datetime-local" @bind="_startAt" />
        </label>

        <label>
            @L["To"]
            <input type="datetime-local" @bind="_endAt" />
        </label>
    </div>

    <div class="row">
        <label>
            @L["Race_Attackers"]: <strong>@_attackerCount</strong>
            <input type="range" min="2" max="200" step="1" @bind="_attackerCount" @bind:event="oninput" />
        </label>
    </div>

    <button type="button" @onclick="FireAsync" disabled="@_running">
        @(_running ? L["Race_Running"] : L["Race_Fire"])
    </button>
</section>

@if (_summary is not null)
{
    <section class="card">
        <p><strong>@string.Format(L["Race_Summary"], _summary.AttackerCount, _summary.Winners, _summary.Conflicts, _summary.OtherErrors)</strong></p>

        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>@L["TableUser"]</th>
                    <th>@L["Race_TableOutcome"]</th>
                    <th>@L["Race_TableReservation"]</th>
                    <th>@L["Race_TableTime"]</th>
                    <th>@L["Race_TableMessage"]</th>
                </tr>
            </thead>
            <tbody>
                @{ var idx = 0; }
                @foreach (var a in _summary.Attackers.OrderBy(a => a.Outcome == "Winner" ? 0 : a.Outcome == "Conflict" ? 1 : 2).ThenBy(a => a.ElapsedMs))
                {
                    idx++;
                    <tr class="@RowClass(a.Outcome)">
                        <td>@idx</td>
                        <td>@a.UserName</td>
                        <td>@LocalizedOutcome(a.Outcome)</td>
                        <td>@(a.ReservationId?.ToString() ?? "—")</td>
                        <td>@a.ElapsedMs</td>
                        <td>@(a.ErrorCode is null ? "" : L[a.ErrorCode].Value)</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private IReadOnlyList<DeskDto> _desks = [];
    private int _deskId = 1;
    private int _attackerCount = 20;
    private DateTime _startAt = DateTime.Today.AddDays(1).AddHours(9);
    private DateTime _endAt   = DateTime.Today.AddDays(1).AddHours(10);
    private bool _running;
    private RaceSummary? _summary;

    protected override async Task OnInitializedAsync()
    {
        _desks = await Service.GetDesksAsync();
        if (_desks.Count > 0) _deskId = _desks[0].Id;
    }

    private async Task FireAsync()
    {
        _running = true;
        _summary = null;

        try
        {
            _summary = await Runner.RunAsync(new RaceParameters(_deskId, _startAt, _endAt, _attackerCount));
        }
        finally
        {
            _running = false;
        }
    }

    private string LocalizedOutcome(string outcome) => outcome switch
    {
        "Winner"   => L["Race_Outcome_Winner"],
        "Conflict" => L["Race_Outcome_Conflict"],
        _          => L["Race_Outcome_Error"]
    };

    private static string RowClass(string outcome) => outcome switch
    {
        "Winner"   => "race-winner",
        "Conflict" => "race-conflict",
        _          => "race-error"
    };
}
